# Telegram bot configuration.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=

# Telegram input. Free text and voice messages are pasted into Codex Desktop.
QLINK_ACCEPT_FREE_TEXT=1
QLINK_COMMAND_PREFIX=/qlink
QLINK_TELEGRAM_REPLY_TO_MESSAGES=1
QLINK_TELEGRAM_REQUEST_TIMEOUT_MS=30000

# Codex Desktop window targeting.
QLINK_TARGET_PROCESS_NAMES=Codex
QLINK_WINDOW_TITLE_PATTERN=Codex
QLINK_FOCUS_DELAY_MS=350
QLINK_AFTER_PASTE_DELAY_MS=150
QLINK_SUBMIT_KEYS={ENTER}
QLINK_AUTO_SUBMIT=1

# Optional click to focus the prompt box before paste.
QLINK_CLICK_INPUT=1
QLINK_CLICK_X_RATIO=0.5
QLINK_CLICK_Y_MODE=bottom-offset
QLINK_CLICK_BOTTOM_OFFSET_PX=105
QLINK_CLICK_Y_RATIO=0.925

# Clipboard behavior. Only text clipboard is restored.
QLINK_RESTORE_CLIPBOARD=1

# QDex audio relay. When a Telegram prompt is injected, relay the next QDex audio broadcast to Telegram.
QLINK_QDEX_ENABLED=1
QLINK_QDEX_SEND_AUDIO_TO_TELEGRAM=1
QLINK_QDEX_BRIDGE_DIR=
QLINK_QDEX_BROADCAST_PATH=
QLINK_QDEX_BROADCAST_POLL_MS=500
QLINK_QDEX_RELAY_TIMEOUT_MS=900000
QLINK_QDEX_AUDIO_CAPTION=

# Local service state.
QLINK_DATA_DIR=data

# Voice transcription.
WHISPER_PATH=
WHISPER_MODEL=
WHISPER_LANGUAGE=auto
WHISPER_THREADS=8
WHISPER_BEAM_SIZE=1
WHISPER_BEST_OF=1
WHISPER_NO_FALLBACK=1
FFMPEG_PATH=
